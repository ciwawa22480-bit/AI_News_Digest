{
  "sources": {
    "google_news_ai": {
      "enabled": true,
      "queries": [
        "OpenAI OR Anthropic OR \"Google AI\" revenue OR launch OR funding",
        "\"Meta AI\" OR \"Microsoft AI\" OR \"Apple AI\" business OR product",
        "ByteDance AI OR Baidu AI OR Alibaba AI OR Tencent AI",
        "Nvidia AI OR xAI OR \"Mistral AI\" funding OR chip OR revenue",
        "AI advertising OR AI commerce OR AI enterprise deal OR AI partnership",
        "AI agent OR AI startup funding OR AI acquisition"
      ],
      "base_url": "https://news.google.com/rss/search",
      "hl": "en-US",
      "gl": "US",
      "ceid": "US:en",
      "when": "5d",
      "max_items_per_query": 12,
      "description": "Google News RSS 大厂 AI 商业动态（核心源）"
    },
    "google_news_cn": {
      "enabled": true,
      "queries": [
        "Baidu AI OR ERNIE",
